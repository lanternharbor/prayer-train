# ─────────────────────────────────────────────────────────────
# PrayerTrain — environment variables
#
# Copy this file to `.env` for local development, or set the same
# keys in your Vercel project (Settings → Environment Variables)
# for production.
#
# Anything marked REQUIRED must be set or the app will not boot.
# Anything marked OPTIONAL only enables that specific feature.
# ─────────────────────────────────────────────────────────────


# ─── Database (REQUIRED) ─────────────────────────────────────
# Neon Postgres connection string. Get from console.neon.tech.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"


# ─── NextAuth / Auth.js (REQUIRED) ───────────────────────────
# In dev: http://localhost:3000
# In production: https://www.ourfaithtrain.com (or your real public URL)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""


# ─── Resend (REQUIRED — magic-link sign-in + transactional email) ──
# Sign up at resend.com and verify the sending domain.
RESEND_API_KEY=""

# OPTIONAL — overrides the default sender. Format: "Name <addr@domain>"
# Defaults to: PrayerTrain <noreply@ourfaithtrain.com>
EMAIL_FROM=""


# ─── Vercel Blob (REQUIRED for recipient photo uploads) ──────
# Vercel Dashboard → Storage → create a Blob store → Read/Write token.
BLOB_READ_WRITE_TOKEN=""


# ─── Cron jobs (REQUIRED for daily reminder emails) ──────────
# Random secret used to authenticate the daily reminder cron handler.
# Generate with: openssl rand -hex 32
# In Vercel, also configure a cron in vercel.json that hits the route.
CRON_SECRET=""


# ─── Google OAuth (OPTIONAL — adds "Continue with Google") ───
# Google Cloud Console → Credentials → OAuth client ID (web app).
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ─── Upstash Redis (OPTIONAL — enables rate limiting) ────────
# Without these, the rate limiter is a no-op and all requests are
# allowed. With them set, the magic-link sign-in endpoint, slot
# claim, guestbook, and create-train server actions are all bucketed.
#
# Easiest path: Vercel Dashboard → Storage → Upstash for Redis
# (free tier). After connecting, the env vars below are populated
# automatically. Or grab them from console.upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─── Sign in with Apple (OPTIONAL — adds "Continue with Apple") ──
# Apple Developer Account is required.
# 1. Create an App ID with "Sign in with Apple" capability
# 2. Create a Services ID — that's your APPLE_ID
# 3. Generate a private key (.p8) with "Sign in with Apple" enabled
# 4. Generate a JWT client secret with: npx auth add apple
# 5. Configure return URL: https://YOUR_DOMAIN/api/auth/callback/apple
APPLE_ID=""
APPLE_SECRET=""


# ─── Vercel auto-set (do NOT set manually) ───────────────────
# VERCEL_URL                        — preview/production deploy URL (host only)
# VERCEL_PROJECT_PRODUCTION_URL     — your stable production hostname
# NODE_ENV                          — "development" / "production" / "test"
